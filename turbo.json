{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "envMode": "loose",
  "globalDependencies": ["pnpm-workspace.yaml", ".npmrc"],
  "tasks": {
    "//#check:imports": {
      "inputs": ["scripts/check-cross-app-imports.mjs", "apps/**"],
      "outputs": []
    },
    "//#check:env-contract": {
      "inputs": ["scripts/check-env-contract.mjs", "apps/**"],
      "outputs": []
    },
    "//#knip": {
      "inputs": [
        "knip.jsonc",
        "package.json",
        "pnpm-workspace.yaml",
        "apps/**",
        "packages/**",
        "scripts/**",
        "turbo/**"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build", "test"],
      "env": ["NODE_ENV", "VERCEL", "VERCEL_ENV"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".eve/**", ".output/**", ".vercel/output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "eval": {
      "cache": false
    },
    "eval:ci": {
      "dependsOn": ["build"],
      "cache": false
    },
    "eval:record": {
      "cache": false
    },
    "info": {
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
