# Shared platform credentials
# Vercel AI Gateway key for live model calls (`pnpm dev`, `eve deploy`, live evals).
# NOT needed for `pnpm run eval:ci` (deterministic mock model) or `pnpm test`.
AI_GATEWAY_API_KEY=

# App-specific variables — always prefixed {{constantCase name}}_ (see agent/lib/env.ts).
{{constantCase name}}_LOG_LEVEL=info
{{#if (eq surface "slack")}}

# Slack surface
# Slack credentials flow through Vercel Connect — no bot token or signing
# secret env vars. See agent/channels/slack.ts for the one-time setup.
{{/if}}
{{#if (eq surface "github")}}

# GitHub surface (GitHub App credentials, read by agent/channels/github.ts)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG={{name}}
{{/if}}
