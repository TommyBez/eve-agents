import { z } from "zod";

// Typed, validated environment access for this app.
//
// Convention: every app-specific variable is prefixed `{{constantCase name}}_`
// (documented in .env.example, cached per the `env` list in turbo.json).
// Parsing is lazy so importing this module never throws — a misconfigured
// environment surfaces on first access, with a precise zod error.
const LOG_LEVELS = ["debug", "info", "warn", "error"] as const;

const envSchema = z.object({
  {{constantCase name}}_LOG_LEVEL: z.enum(LOG_LEVELS).default("info"),
  // Add required variables as the agent grows, e.g.:
  // {{constantCase name}}_API_URL: z.url(),
});

export type Env = z.infer<typeof envSchema>;

let cached: Env | undefined;

export function env(): Env {
  cached ??= envSchema.parse(process.env);
  return cached;
}
