# Copy to .env.local for local development (or `vercel env pull` on a linked
# project). Unit tests and `pnpm run eval:ci` need none of these.

# --- Model / gateway --------------------------------------------------------
# Vercel AI Gateway key for the production model (anthropic/claude-sonnet-5).
# Not needed on Vercel deployments (OIDC) or for mock-model eval runs.
AI_GATEWAY_API_KEY=

# --- GitHub App -------------------------------------------------------------
# Numeric App ID from the GitHub App settings page.
GITHUB_APP_ID=
# Private key PEM; replace literal newlines with \n for single-line storage.
GITHUB_APP_PRIVATE_KEY=
# Must match the webhook secret configured on the GitHub App.
GITHUB_WEBHOOK_SECRET=
# App slug users mention on PRs; defaults to "code-reviewer" when unset.
GITHUB_APP_SLUG=code-reviewer

# --- Rate limiting (Upstash Redis REST) --------------------------------------
# Read/write REST credentials. When unset, rate limiting is unavailable and
# the failure mode below applies (default blocks public repos only).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Master switch; defaults to true. Set to false for local development only.
CODE_REVIEWER_RATE_LIMIT_ENABLED=
# Behavior when Upstash is unavailable: open | closed | public_closed (default).
CODE_REVIEWER_RATE_LIMIT_FAILURE_MODE=
# Redis key prefix; defaults to "evex:code-reviewer".
CODE_REVIEWER_RATE_LIMIT_PREFIX=
# Seconds between reviews per PR; defaults to 900.
CODE_REVIEWER_PR_COOLDOWN_SECONDS=
# Seconds between reviews per user per PR; defaults to 1800.
CODE_REVIEWER_USER_PR_COOLDOWN_SECONDS=
# Reviews per private repository per day; defaults to 25.
CODE_REVIEWER_PRIVATE_REPO_DAILY_LIMIT=
# Reviews per public repository per day; defaults to 10.
CODE_REVIEWER_PUBLIC_REPO_DAILY_LIMIT=
# Post a "cooling down" reply when a mention is rate limited; defaults to true.
CODE_REVIEWER_COOLDOWN_REPLY=
# Seconds between cooldown replies per PR; defaults to 900.
CODE_REVIEWER_COOLDOWN_REPLY_SECONDS=

# --- Testing ----------------------------------------------------------------
# Set to 1 to swap the model for a deterministic fixture; used automatically
# by `pnpm run eval:ci`. Never set this in production.
# EVE_MOCK_MODEL=1
# Set to 1 to record model responses into evals/fixtures/recordings.json; used
# automatically by `pnpm run eval:record`. Never set this in production.
# EVE_RECORD_FIXTURES=1
