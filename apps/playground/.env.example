# Copy to .env.local for local development. The playground needs no env vars
# at all for local (`kind: "local"`) targets on a dev machine.
#
# Per-agent overrides (names derived from the agent id, CONSTANT_CASE):
#
# - PLAYGROUND_<ID>_URL — full base URL that overrides the config target for
#   that agent. This is how a DEPLOYED playground reaches agents that are
#   `kind: "local"` in agents.config.json. When unset on Vercel, loopback
#   targets render as "not available in this deployment".
#   Example: PLAYGROUND_CODE_REVIEWER_URL=https://code-reviewer.example.com
#
# - PLAYGROUND_<ID>_AUTH (or the var named by "target.authHeaderEnv") — the
#   FULL Authorization header value the proxy attaches, e.g. "Bearer <token>".
#   Both names are read via `process.env[name]` indirection: they derive from
#   agents.config.json ids, so they cannot be listed here exhaustively.
PLAYGROUND_CODE_REVIEWER_AUTH=

# Opt-in HTTP Basic auth for DEPLOYED playgrounds (format: user:password).
# When set, every route (pages and /api/agents/*) requires these credentials;
# when unset, the playground is open (fine locally, never fine deployed —
# see docs/playground.md "Deploying the playground").
PLAYGROUND_BASIC_AUTH=
