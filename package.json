{
  "name": "eve-agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "agent:new": "turbo gen agent",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "eval": "turbo run eval",
    "eval:ci": "turbo run eval:ci",
    "format": "biome format --write .",
    "info": "turbo run info",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "node scripts/check-cross-app-imports.mjs && turbo run lint typecheck build test eval:ci"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@turbo/gen": "^2.10.2",
    "turbo": "^2.10.2"
  },
  "engines": {
    "node": "24.x"
  }
}
